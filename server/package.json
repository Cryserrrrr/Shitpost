{
  "name": "shitpost-server",
  "version": "1.0.0",
  "description": "Shitpost - Server for real-time meme broadcasting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "set TS_NODE_TRANSPILE_ONLY=true && ts-node src/index.ts",
    "watch": "set TS_NODE_TRANSPILE_ONLY=true && nodemon --exec ts-node src/index.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.10.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "prisma": "^6.7.0",
    "socket.io": "^4.7.4",
    "typescript": "^5.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1"
  },
  "author": "",
  "license": "MIT"
}
