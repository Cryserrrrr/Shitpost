{
  "name": "live-chat-server",
  "version": "1.0.0",
  "description": "Node.js TypeScript server with Socket.io for live media broadcasting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "nodemon --exec ts-node src/index.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "socket.io-client": "^4.7.4"
  },
  "keywords": [
    "socket.io",
    "typescript",
    "websocket",
    "media",
    "broadcast"
  ],
  "author": "",
  "license": "MIT"
}
