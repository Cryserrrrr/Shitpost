{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "live-chat",
  "version": "0.1.0",
  "identifier": "com.cryser.live-chat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meme Studio",
        "width": 1000,
        "height": 700,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "decorations": true,
        "transparent": false,
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "closable": true,
        "visible": true
      },
      {
        "label": "overlay",
        "title": "Overlay",
        "url": "overlay.html",
        "visible": true,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "hiddenTitle": true,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "closable": false,
        "fullscreen": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
