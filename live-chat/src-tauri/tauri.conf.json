{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shitpost",
  "version": "0.2.0",
  "identifier": "com.cryser.shitpost",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shitpost",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "closable": true,
        "visible": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Overlay",
        "url": "overlay.html",
        "visible": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "hiddenTitle": true,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "closable": false,
        "fullscreen": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ws: wss: http: https:; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost"
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Cryserrrrr/Shitpost/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExOTNDRjlCMzc0MEJFNjQKUldSa3ZrQTNtOCtURVltbEx6NTFvRXRwQ1BMK2hOWDFFQTFDSzl5aUFzb1JHTnVBY1RhZ05pcU8K"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["shitpost"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
